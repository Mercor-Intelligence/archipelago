# Archipelago Grading - Example Configuration
# Copy this file to .env and fill in values as needed

# Environment type: local, dev, demo, prod
ENV=local

# =============================================================================
# LLM Provider API Keys (at least one required for LLM-based verifiers)
# =============================================================================
# Anthropic (recommended for grading)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# OR use LiteLLM Proxy for all LLM requests
LITELLM_PROXY_API_BASE=
LITELLM_PROXY_API_KEY=

# =============================================================================
# Document Extraction (optional but recommended for PDFs, Office docs)
# =============================================================================
# Preferred: route through Mercor's document cache so identical files across
# snapshots/trajectories only get parsed once. Both vars must be set;
# otherwise the grading service falls back to its direct parser.
#   MERCOR_DOCUMENT_API     — full URL of the parse endpoint (per-env constant)
#                             e.g. https://api.studio.mercor.com/internal/archipelago/document-cache/parse
#   MERCOR_DOCUMENT_API_KEY — internal API key (same value as INTERNAL_API_KEY)
MERCOR_DOCUMENT_API=
MERCOR_DOCUMENT_API_KEY=

# Direct Reducto API key. Used as a fallback when MERCOR_DOCUMENT_API /
# MERCOR_DOCUMENT_API_KEY are not set (typical for local dev). Ignored when
# the Mercor document cache is enabled.
REDUCTO_API_KEY=

# Firecrawl for web content extraction
ACE_FIRECRAWL_API_KEY=

# =============================================================================
# Webhook for saving results (optional)
# =============================================================================
SAVE_WEBHOOK_URL=
SAVE_WEBHOOK_API_KEY=
SCORE_WEBHOOK_URL=

# =============================================================================
# Datadog logging (optional)
# =============================================================================
DATADOG_LOGGING=false
DATADOG_API_KEY=
DATADOG_APP_KEY=
