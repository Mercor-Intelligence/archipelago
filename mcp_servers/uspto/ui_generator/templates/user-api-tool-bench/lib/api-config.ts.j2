/** Field definition for nested object sub-fields */
export interface FieldDefinition {
  name: string;
  label: string;
  type: 'string' | 'number' | 'boolean' | 'date' | 'datetime' | 'object' | 'array';
  required: boolean;
  description: string;
  minLength?: number;
  maxLength?: number;
  min?: number;
  max?: number;
  enum?: string[];
  default?: any;
  /** Whether this field accepts multiple values */
  isList?: boolean;
  /** For nested object fields, the sub-field definitions */
  fields?: FieldDefinition[];
}

export interface DataType {
  id: string;
  name: string;
  category: string;
  description: string;
  icon?: string;
  server: string;
  _internal: {
    method: 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';
    url: string;
    requiresAuth: boolean;
  };
  parameters?: {
    name: string;
    label: string;
    type: 'string' | 'number' | 'boolean' | 'date' | 'datetime' | 'object' | 'array';
    required: boolean;
    description: string;
    placeholder?: string;
    location: 'query' | 'body' | 'header' | 'path';
    minLength?: number;
    maxLength?: number;
    min?: number;
    max?: number;
    enum?: string[];
    enumDescriptions?: Record<string, string>;
    pattern?: string;
    jsonExample?: string;
    isJsonField?: boolean;
    default?: any;
    /** Whether this parameter accepts multiple values (rendered as a list with add/remove) */
    isList?: boolean;
    /** For object types, the sub-field definitions for structured input */
    fields?: FieldDefinition[];
  }[];
}

{# Macro for rendering field definitions recursively #}
{% macro render_fields(fields) %}
[
{% for field in fields %}
      {
        name: '{{ field.name }}',
        label: '{{ field.label }}',
        type: '{{ field.type }}',
        required: {{ field.required | lower }},
        description: {{ field.description | tojson }},
        {% if field.minLength is defined %}minLength: {{ field.minLength }},{% endif %}
        {% if field.maxLength is defined %}maxLength: {{ field.maxLength }},{% endif %}
        {% if field.min is defined %}min: {{ field.min }},{% endif %}
        {% if field.max is defined %}max: {{ field.max }},{% endif %}
        {% if field.enum %}enum: {{ field.enum | tojson }},{% endif %}
        {% if field.default is defined %}default: {{ field.default | tojson }},{% endif %}
        {% if field.isList %}isList: true,{% endif %}
        {% if field.fields %}fields: {{ render_fields(field.fields) }},{% endif %}
      },
{% endfor %}
    ]
{% endmacro %}

export const dataTypes: DataType[] = [
