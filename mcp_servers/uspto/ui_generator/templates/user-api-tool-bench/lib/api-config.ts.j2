// API Model Documentation
export interface ModelField {
  type: string;
  required: boolean;
  description: string;
  default: string | null;
}

export interface Model {
  name: string;
  docstring: string;
  fields: Record<string, ModelField>;
  bases: string[];
  is_enum: boolean;
}

export const models: Model[] = {{ models | tojson }};

export function getModelByName(name: string): Model | undefined {
  return models.find(m => m.name === name);
}
