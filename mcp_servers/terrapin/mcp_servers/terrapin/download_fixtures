def download_inflation_factors(
    client: httpx.Client, countries: list[str], days: int = 365
) -> list[dict]:
    """Download inflation factors for specified countries."""
    if not countries:
        return []

    logger.info(f"Downloading inflation factors for {len(countries)} countries...")
    start_date, end_date = _get_date_range(days)

    all_factors = []
    for country in countries:
        try:
            response = _request_with_retry(
                client,
                "post",
                "/inflation_factors",
                json={"country": country, "start_date": start_date, "end_date": end_date},
            )
            factors = _extract_list(response.json(), "factors")
            all_factors.extend(factors)
        except httpx.HTTPStatusError as e:
            logger.warning(f"HTTP error for {country}: {e.response.status_code}")
        except Exception as e:
            logger.warning(f"Error for {country}: {e}")

    logger.info(f"Downloaded {len(all_factors)} inflation factor records")
    return all_factors


def insert_bonds(conn, bonds: list[dict]) -> int:
    """Insert bonds into DuckDB."""
    for bond in bonds:
        try:
            conn.execute(
                """
                INSERT OR REPLACE INTO bonds
                (isin, issuer_name, ticker, coupon, coupon_frequency, interest_type,
                 maturity_date, issue_date, currency, country, issue_rating,
                 issue_rating_group, issuer_rating, asset_class, sector)
                VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """,
                [
                    bond.get("isin"),
                    bond.get("issuer_name"),
                    bond.get("ticker"),
                    bond.get("coupon"),
                    bond.get("coupon_frequency"),
                    bond.get("interest_type"),
                    bond.get("maturity_date"),
                    bond.get("issue_date"),
                    bond.get("currency"),
                    bond.get("country"),
                    bond.get("issue_rating"),
                    bond.get("issue_rating_group"),
                    bond.get("issuer_rating"),
                    bond.get("asset_class"),
                    bond.get("sector"),
                ],
            )
        except Exception as e:
            logger.error(f"Failed to insert bond: {e}")
            sys.exit(1)

    return len(bonds)


