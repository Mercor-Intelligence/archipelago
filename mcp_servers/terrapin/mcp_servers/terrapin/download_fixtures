def _serialize_for_json(value):
    """Convert Python objects to JSON-serializable values."""
    if isinstance(value, datetime):
        return value.isoformat()
    if isinstance(value, date):
        return value.strftime("%Y-%m-%d")
    if isinstance(value, list):
        return [_serialize_for_json(v) for v in value]
    if isinstance(value, dict):
        return {k: _serialize_for_json(v) for k, v in value.items()}
    return value


def export_to_json(conn, output_dir: Path) -> None:
    """Export DuckDB tables to JSON files for offline mode."""
    output_dir.mkdir(parents=True, exist_ok=True)

    table_mappings = [
        ("bonds", "sample_bonds.json"),
        ("bond_reference", "sample_bond_reference.json"),
        ("bond_pricing", "sample_bond_pricing.json"),
        ("bond_cashflows", "sample_bond_cashflows.json"),
        ("muni_bonds", "sample_muni_bonds.json"),
        ("muni_reference", "sample_muni_reference.json"),
        ("muni_pricing", "sample_muni_pricing.json"),
        ("muni_cashflows", "sample_muni_cashflows.json"),
        ("inflation_factors", "sample_inflation_factors.json"),
    ]

    for table, filename in table_mappings:
        result = conn.execute(f"SELECT COUNT(*) FROM {table}").fetchone()
        if result[0] == 0:
            continue

        cursor = conn.execute(f"SELECT * FROM {table}")
        columns = [desc[0] for desc in cursor.description]
        rows = cursor.fetchall()

        records = []
        for row in rows:
            record = {}
            for col, val in zip(columns, row):
                record[col] = _serialize_for_json(val)
            records.append(record)

        filepath = output_dir / filename
        with open(filepath, "w") as f:
            json.dump(records, f, indent=2)

        logger.info(f"Exported {len(records)} records to {filename}")


class QuietCommand(click.Command):
    """Command that doesn't print usage on error."""

    def main(self, *args, **kwargs):
        try:
            return super().main(*args, standalone_mode=False, **kwargs)
        except click.UsageError as e:
            msg = e.format_message()
            sep = "; " if msg.endswith(")") else " ("
            logger.error(msg.removesuffix(")") + sep + "--help for usage)")
            sys.exit(2)


@click.command(cls=QuietCommand)
@click.option("--api-key", envvar="TERRAPIN_API_KEY", help="Terrapin API key")
@click.option(
    "--base-url",
    envvar="TERRAPIN_API_BASE_URL",
    default="https://terrapinfinance.com/api/v1",
    help="Terrapin API base URL",
)
@click.option("--all", "download_all", is_flag=True, help="Download all data types")
@click.option("--bonds", is_flag=True, help="Download corporate/government bonds")
@click.option("--muni", is_flag=True, help="Download municipal bonds")
@click.option("--pricing", is_flag=True, help="Download pricing data")
@click.option("--pricing-days", default=30, help="Days of pricing history to download")
@click.option("--limit", default=1000, help="Maximum bonds per category (0 for unlimited)")
@click.option("--reset", is_flag=True, help="Reset database before downloading")
@click.option("--export-json", is_flag=True, help="Export DuckDB tables to data/*.json files")
@click.option("--verbose", "-v", count=True, help="Verbose output (-v for INFO, -vv for DEBUG)")
def main(
    api_key: str,
    base_url: str,
    download_all: bool,
    bonds: bool,
    muni: bool,
    pricing: bool,
    pricing_days: int,
    limit: int,
    reset: bool,
    export_json: bool,
    verbose: int,
):
    """Download Terrapin fixture data into local DuckDB."""
    logger.remove()
    logger.add(sys.stderr, format="ERROR: {message}", level="ERROR")
    match verbose:
        case 1:
            logger.add(sys.stderr, format="{message}", level="INFO", filter=lambda r: r["level"].no < 40)
        case 2:
            logger.add(sys.stderr, level="DEBUG", filter=lambda r: r["level"].no < 40)

    if not api_key:
        logger.error("TERRAPIN_API_KEY not set.  Provide via --api-key or environment variable.")
        sys.exit(1)

    if download_all:
        bonds = muni = pricing = True

    # Convert limit=0 to None (unlimited)
    if limit == 0:
        limit = None

    if not any([bonds, muni, pricing]):
        logger.error("Specify --all or at least one of --bonds, --muni, --pricing")
        sys.exit(1)

    if reset:
        logger.info("Resetting database...")
        reset_database()

    conn = get_connection()
    client = get_api_client(api_key, base_url)

    bond_isins = []
    muni_isins = []

    try:
        if bonds:
            bond_data = download_bonds(client, limit)
            insert_bonds(conn, bond_data)
            bond_isins = [b.get("isin") for b in bond_data if b.get("isin")]

            bond_ref = download_bond_reference(client, bond_isins)
            insert_bond_reference(conn, bond_ref)

            bond_cf = download_bond_cashflows(client, bond_isins)
            insert_bond_cashflows(conn, bond_cf)

            countries = list({
                _normalize_country_code(b.get("country"))
                for b in bond_data if b.get("country")
            })
            inflation = download_inflation_factors(client, countries, days=pricing_days)
            insert_inflation_factors(conn, inflation)

        if muni:
            muni_data = download_muni_bonds(client, limit)
            insert_muni_bonds(conn, muni_data)
            muni_isins = [b.get("isin") for b in muni_data if b.get("isin")]

            muni_ref = download_muni_reference(client, muni_isins)
            insert_muni_reference(conn, muni_ref)

            muni_cf = download_muni_cashflows(client, muni_isins)
            insert_muni_cashflows(conn, muni_cf)

        if pricing:
            if not bond_isins:
                bond_isins = [r[0] for r in conn.execute("SELECT isin FROM bonds").fetchall()]
            if not muni_isins:
                muni_isins = [r[0] for r in conn.execute("SELECT isin FROM muni_bonds").fetchall()]

            if not bond_isins and not muni_isins:
                logger.error("No bonds in database.  Run with --bonds or --muni first.")
                sys.exit(1)

            if bond_isins:
                bond_pricing = download_bond_pricing(client, bond_isins, pricing_days)
                insert_bond_pricing(conn, bond_pricing)

            if muni_isins:
                muni_pricing_data = download_muni_pricing(client, muni_isins, pricing_days)
                insert_muni_pricing(conn, muni_pricing_data)

        logger.info("Download complete!")
        print_summary(conn)

        if export_json:
            data_dir = Path(__file__).parent / "data"
            logger.info(f"Exporting to {data_dir}...")
            export_to_json(conn, data_dir)

    finally:
        client.close()


if __name__ == "__main__":
    main()
