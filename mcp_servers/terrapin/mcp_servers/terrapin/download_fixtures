def _normalize_country_code(country: str) -> str:
    """Convert country name to 2-letter ISO code."""
    if len(country) == 2 and country.isupper():
        return country
    return COUNTRY_CODE_MAP.get(country, country)


def get_api_client(api_key: str, base_url: str) -> httpx.Client:
    """Create an authenticated HTTP client."""
    return httpx.Client(
        base_url=base_url,
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": "application/json",
        },
        timeout=60.0,
    )


def _request_with_retry(
    client: httpx.Client,
    method: str,
    endpoint: str,
    max_retries: int = 5,
    base_delay: float = 1.0,
    max_delay: float = 60.0,
    **kwargs,
) -> httpx.Response:
    """Make HTTP request with exponential backoff on rate limits.

    Args:
        client: HTTP client
        method: HTTP method (get, post, etc.)
        endpoint: API endpoint
        max_retries: Maximum number of retry attempts
        base_delay: Initial delay in seconds
        max_delay: Maximum delay in seconds
        **kwargs: Additional arguments passed to client request

    Returns:
        HTTP response

    Raises:
        httpx.HTTPStatusError: If request fails after all retries
    """
    last_exception = None

    for attempt in range(max_retries + 1):
        try:
            response = getattr(client, method)(endpoint, **kwargs)

            if response.status_code == 429:
                if attempt == max_retries:
                    response.raise_for_status()

                # Use retry-after header if available
                retry_after = response.headers.get("retry-after")
                if retry_after:
                    delay = float(retry_after)
                else:
                    # Exponential backoff with jitter
                    delay = min(base_delay * (2**attempt) + random.uniform(0, 1), max_delay)

                logger.warning(f"Rate limited, waiting {delay:.1f}s (attempt {attempt + 1}/{max_retries + 1})")
                time.sleep(delay)
                continue

            response.raise_for_status()
            return response

        except httpx.HTTPStatusError as e:
            if e.response.status_code != 429:
                raise
            last_exception = e

    if last_exception:
        raise last_exception
    raise httpx.HTTPStatusError("Max retries exceeded", request=None, response=None)


def _extract_list(data: dict | list, key: str) -> list[dict]:
    """Extract list from API response, handling various response formats."""
    logger.debug(f"_extract_list input: {type(data)}, key={key}")
    logger.debug(f"_extract_list data: {data}")

    if isinstance(data, list):
        return data

    if not isinstance(data, dict):
        return []

    extracted = data.get(key)
    if extracted is None:
        extracted = data.get("data")
    if extracted is None:
        return []
    logger.debug(f"_extract_list extracted: {type(extracted)}")

    if isinstance(extracted, list):
        return extracted

    if isinstance(extracted, dict):
        return list(extracted.values())

    return []


def _extract_response(data: dict) -> tuple[list[dict], int | None]:
    """Extract data list and total count from API response.

    Returns:
        Tuple of (data list, total count or None if not present)
    """
    if not isinstance(data, dict):
        return [], None

    items = data.get("data", [])
    if not isinstance(items, list):
        items = []

    total = data.get("total")
    if total is not None:
        try:
            total = int(total)
        except (ValueError, TypeError):
            total = None

    return items, total


def _get_date_range(days: int) -> tuple[str, str]:
    """Get start and end date strings for a given number of days back."""
    end_date = datetime.now().strftime("%Y-%m-%d")
    start_date = (datetime.now() - timedelta(days=days)).strftime("%Y-%m-%d")
    return start_date, end_date


def download_bonds(
    client: httpx.Client, limit: int | None = None, batch_size: int = 10000
) -> list[dict]:
    """Download bond reference data with pagination.

    Uses incremental JSON calls with limit/offset pagination as recommended
    by Terrapin Finance API (batch_size=10000 for network resilience).

    Args:
        client: HTTP client
        limit: Maximum bonds to download, or None for all available
        batch_size: Number of bonds per API request (default 10000)
    """
    all_bonds = []
    offset = 0
    total = None

    logger.info(f"Downloading bonds (limit={limit or 'all'})...")

    while True:
        try:
            # Calculate batch limit
            if limit is not None:
                remaining = limit - len(all_bonds)
                if remaining <= 0:
                    break
                current_batch = min(batch_size, remaining)
            else:
                current_batch = batch_size

            response = _request_with_retry(
                client, "post", "/bond_search", json={"limit": current_batch, "offset": offset}
            )

            bonds, total = _extract_response(response.json())

            if not bonds:
                break

            all_bonds.extend(bonds)
            offset += len(bonds)

            if total is not None:
                logger.info(f"Downloaded {len(all_bonds)}/{total} bonds")
            else:
                logger.info(f"Downloaded {len(all_bonds)} bonds")

            # Stop if we got fewer than requested (no more data)
            if len(bonds) < current_batch:
                break

            # Stop if we've reached total
            if total is not None and offset >= total:
                break

        except httpx.HTTPStatusError as e:
            logger.error(f"HTTP error downloading bonds: {e.response.status_code}")
            break
        except Exception as e:
            logger.error(f"Error downloading bonds: {e}")
            break

    logger.info(f"Downloaded {len(all_bonds)} bonds total")
    return all_bonds


