def insert_inflation_factors(conn, factors: list[dict]) -> int:
    """Insert inflation factors into DuckDB."""
    inserted = 0
    for record in factors:
        try:
            country = record.get("country_code")
            if country is None:
                country = record.get("country")
            if not country:
                logger.warning(f"Skipping inflation factor with no country: {record}")
                continue
            country = _normalize_country_code(country)
            conn.execute(
                """
                INSERT OR REPLACE INTO inflation_factors
                (country_code, factor_date, inflation_factor)
                VALUES (?, ?, ?)
                """,
                [
                    country,
                    record.get("factor_date") if record.get("factor_date") is not None else record.get("date"),
                    record.get("inflation_factor") if record.get("inflation_factor") is not None else record.get("factor"),
                ],
            )
            inserted += 1
        except Exception as e:
            logger.error(f"Failed to insert inflation factor: {e}")
            sys.exit(1)

    return inserted


