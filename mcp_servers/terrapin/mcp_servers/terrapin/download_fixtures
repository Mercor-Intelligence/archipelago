def _download_in_batches(
    client: httpx.Client,
    endpoint: str,
    isins: list[str],
    extra_params: dict,
    result_key: str,
    batch_size: int = 50,
) -> list[dict]:
    """Download data for ISINs in batches to avoid request limits."""
    all_results = []

    for i in range(0, len(isins), batch_size):
        batch = isins[i : i + batch_size]
        try:
            payload = {"isins": batch, **extra_params}
            response = _request_with_retry(client, "post", endpoint, json=payload)
            results = _extract_list(response.json(), result_key)
            all_results.extend(results)

        except httpx.HTTPStatusError as e:
            logger.warning(f"HTTP error for batch {i // batch_size}: {e.response.status_code}")
        except Exception as e:
            logger.warning(f"Error for batch {i // batch_size}: {e}")

    return all_results


def download_bond_pricing(
    client: httpx.Client, isins: list[str], days: int = 30
) -> list[dict]:
    """Download bond pricing history."""
    if not isins:
        return []

    logger.info(f"Downloading pricing for {len(isins)} bonds, last {days} days...")
    start_date, end_date = _get_date_range(days)

    pricing = _download_in_batches(
        client,
        "/bond_pricing_history",
        isins,
        {"start_date": start_date, "end_date": end_date},
        "pricing",
    )

    logger.info(f"Downloaded {len(pricing)} pricing records")
    return pricing


