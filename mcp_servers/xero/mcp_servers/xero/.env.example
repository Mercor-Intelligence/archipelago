# Xero MCP Server Configuration

# Offline mode: true = synthetic data, false = live Xero API (requires OAuth credentials)
XERO_OFFLINE_MODE=true

# OAuth Configuration (required for online mode only)
XERO_CLIENT_ID=your_client_id_here
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:8080/callback
XERO_SCOPES=openid profile email offline_access accounting.settings.read accounting.transactions.read accounting.reports.read
# File path where OAuth tokens are persisted
XERO_TOKEN_STORE_PATH=.xero_tokens.json
# Tokens received from authorization (optional seeding for tests)
XERO_ACCESS_TOKEN=
XERO_REFRESH_TOKEN=
# Token lifetime in seconds when seeding the store manually
XERO_ACCESS_TOKEN_EXPIRES_IN=1800
# Your tenant ID (from the Connections endpoint)
XERO_TENANT_ID=
# Shared OAuth PKCE helper path (see README)
OAUTH_PKCE_MODULE_PATH=
# Integration test toggles
XERO_RUN_ONLINE_TESTS=0
XERO_ALLOW_TOKEN_ROTATION=0
# Seed the offline database with demo accounts when enabled (default: false/safe)
XERO_SEED_DEMO_DATA=0
# Logging
LOG_LEVEL=INFO
