export function getDataTypeById(id: string): DataType | undefined {
  return dataTypes.find(dt => dt.id === id);
}

export function getDataTypesByCategory(): Record<string, DataType[]> {
  return dataTypes.reduce((acc, dt) => {
    if (!acc[dt.category]) {
      acc[dt.category] = [];
    }
    acc[dt.category].push(dt);
    return acc;
  }, {} as Record<string, DataType[]>);
}

export function getDataTypesByServer(): Record<string, DataType[]> {
  return dataTypes.reduce((acc, dt) => {
    if (!acc[dt.server]) {
      acc[dt.server] = [];
    }
    acc[dt.server].push(dt);
    return acc;
  }, {} as Record<string, DataType[]>);
}

// API Model Documentation
export interface ModelField {
  type: string;
  required: boolean;
  description: string;
  default: string | number | boolean | null | unknown[];
  /** Pre-extracted enum values from Literal types */
  enum?: string[];
  /** Whether this field is a list (renders as add/remove list) */
  isList?: boolean;
  /** Reference to a model name for nested object types */
  modelRef?: string;
}

export interface Model {
  name: string;
  docstring: string;
  fields: Record<string, ModelField>;
  bases: string[];
  is_enum: boolean;
}

export const models: Model[] = {{ models | tojson }};

export function getModelByName(name: string): Model | undefined {
  return models.find(m => m.name === name);
}

/**
 * Get tool endpoint from URL (e.g., "/tools/login_tool" -> "login_tool")
 * This is more reliable than using display name transformation
 */
export function getToolEndpoint(dt: DataType): string {
  const url = dt._internal?.url || '';
  return url.split('/').pop() || dt.name.toLowerCase().replace(/\s+/g, '_');
}

