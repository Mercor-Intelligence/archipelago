#!/bin/sh

# A brain-dead script to create milestones in github.  Before
# running this script, you should authenticate with 'gh auth login'
# Specify the name of the repo as the first argument.

repo=${1?}
base_date=${2-$(date +%s)}  # seconds from epoch, default to today

gh auth status || gh auth login || exit

create_milestone() {

	title=${1?}
	: $((base_date += ${2-0} * 86400))
	due_date=$(date -f %s -j "$base_date" "+%Y-%m-%dT23:59:59Z")
	description=${3}
	GH_PAGER= gh api repos/Mercor-Intelligence/$repo/milestones \
		-f title="$title" \
		${description:+-f description="$description"} \
		${due_date:+-f due_on="$due_date"} || exit
}


