# Standard MCP Server Makefile
# Generated by mercor-mcp framework
# This is a TEMPLATE for individual MCP server projects (e.g., mercor-SAP).
# It is NOT used by the mercor-mcp framework itself.
# Customize SERVER_NAME for your project.

SERVER_NAME ?= edgar_sec
TEST_PATH ?= tests/
SERVER_PATH ?= mcp_servers/$(SERVER_NAME)/

.PHONY: help install lint format test coverage security check clean

help:
	@echo "MCP Server Development Commands"
	@echo ""
	@echo "  make install    - Install dependencies"
	@echo "  make lint       - Run linting (ruff check)"
	@echo "  make format     - Format code (ruff format)"
	@echo "  make test       - Run tests"
	@echo "  make coverage   - Run tests with coverage"
	@echo "  make security   - Run security scan (bandit)"
	@echo "  make check      - Run all checks (lint, format check, test)"
	@echo "  make clean      - Remove cache files"

install:
	uv sync --all-extras

lint:
	uv run ruff check .

format:
	uv run ruff format .

test:
	uv run pytest $(TEST_PATH) -v --tb=short

coverage:
	uv run pytest $(TEST_PATH) --cov=$(SERVER_PATH) --cov-report=html --cov-report=term-missing

security:
	uv run bandit -r $(SERVER_PATH) -ll -f txt

check: lint
	uv run ruff format --check .
	uv run pytest $(TEST_PATH) -v --tb=short

clean:
	find . -type d -name __pycache__ -exec rm -rf {} +
	find . -type d -name .ruff_cache -exec rm -rf {} +
	find . -type d -name .pytest_cache -exec rm -rf {} +
	find . -type d -name htmlcov -exec rm -rf {} +
	find . -type f -name "*.pyc" -delete
	find . -type f -name ".coverage" -delete
