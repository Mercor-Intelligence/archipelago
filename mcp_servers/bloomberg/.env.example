# Bloomberg MCP Server Configuration
# Copy this file to .env and adjust values as needed

# Data Mode
# Set to "offline" to use local database, "online" for live data (default: online)
MODE=online

# Data Source
# Set to true to use mock data (no OpenBB required)
MOCK_OPENBB=true

# Python Path (for running the server)
PYTHONPATH=src

# Open BB API Keys
ALPHA_VANTAGE_KEY=
BENZINGA_KEY=
BIZTOC_KEY=
BLS_KEY=
CBOE_KEY=
CFTC_KEY=
CONGRESS_KEY=
DERIBIT_KEY=
ECB_KEY=
ECONDB_KEY=
FAMA_FRENCH_KEY=
FEDERAL_RESERVE_KEY=
FINRA_KEY=
FINVIZ_KEY=
FMP_API_KEY=
FRED_KEY=
GOV_US_KEY=
IMF_KEY=
INTRINIO_KEY=
MULTPL_KEY=
NASDAQ_KEY=
OECD_KEY=
POLYGON_KEY=
SEC_KEY=
SEEKING_ALPHA_KEY=
STOCKGRID_KEY=
TIINGO_KEY=
TMX_KEY=
TRADIER_KEY=
TRADINGECONOMICS_KEY=
US_EIA_KEY=
WSJ_KEY=
YFINANCE_KEY=

