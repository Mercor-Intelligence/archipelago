# FMP MCP Server Environment Variables
# Copy this file to .env and fill in your values

# API Key for online mode (get one at https://financialmodelingprep.com/)
# Leave empty or remove to use offline mode
# FMP_API_KEY=your_api_key_here

# Force offline mode (optional, defaults to false)
FMP_OFFLINE_MODE=true

# Database URL (optional, defaults to local SQLite)
# FMP_DATABASE_URL=sqlite+aiosqlite:///./data/fmp.db

# Log level (optional, defaults to INFO)
# FMP_LOG_LEVEL=DEBUG
