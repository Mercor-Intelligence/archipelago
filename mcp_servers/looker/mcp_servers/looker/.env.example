# Environment configuration for looker
# Copy this to .env and fill in your values

# Tool Registration Mode
# GUI_ENABLED=false  # Default: Use 7 meta-tools optimized for LLM agents
# GUI_ENABLED=true   # Use 30+ individual tools for GUI display

# Mode Control
# Mode is AUTO-DETECTED based on credentials:
#   - If credentials below are provided → online mode (connects to Looker API)
#   - If no credentials → offline mode (uses mock data)
#
# Explicitly override auto-detection (optional):
# OFFLINE_MODE=true   # Force offline mode even with credentials
# OFFLINE_MODE=false  # Force online mode (requires credentials)

# Looker API Configuration (required for online mode)
# LOOKER_BASE_URL=https://your-company.looker.com:19999
# LOOKER_CLIENT_ID=your_client_id_here
# LOOKER_CLIENT_SECRET=your_client_secret_here
# LOOKER_VERIFY_SSL=true
# LOOKER_TIMEOUT=120

# SQL Runner Timeout Configuration (optional)
# LOOKER_SQL_CREATE_TIMEOUT=10  # Timeout for SQL query creation step (seconds)
# LOOKER_SQL_RUN_TIMEOUT=30     # Timeout for SQL query execution step (seconds)

# Hybrid Mode (optional)
# Use captured real data in offline mode without API credentials
# CAPTURED_DATA_FILE=../../data/looker/captured/your_capture.json

# General Settings
# DEBUG=false
