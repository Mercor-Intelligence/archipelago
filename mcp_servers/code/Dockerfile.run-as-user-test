# Faithful root+gemini environment to validate the run-as-user boundary
# end-to-end against the REAL run_sandboxed_command. Runs on a GitHub runner.
FROM python:3.13-slim

RUN apt-get update && apt-get install -y --no-install-recommends util-linux \
    && rm -rf /var/lib/apt/lists/*
RUN pip install --no-cache-dir loguru

# Unprivileged user the model's commands drop to.
RUN useradd -m -s /bin/bash gemini

# Root-owned app code + data, locked to the owner only (chmod 700).
RUN mkdir -p /app/tools/mcp_servers \
    && echo "TOP_SECRET_APP_zzz" > /app/secret.txt \
    && chmod 700 /app
RUN mkdir -p /.apps_data/quickbooks \
    && echo "SECRET_DB_yyy" > /.apps_data/quickbooks/data.db \
    && chmod 700 /.apps_data

# The model's own readable/writable space.
RUN echo "model-can-read-this" > /home/gemini/ok.txt \
    && chown -R gemini:gemini /home/gemini
RUN mkdir -p /filesystem && chown gemini:gemini /filesystem

# The REAL service module under test + the driver.
COPY mcp_servers/code_execution_server/utils/sandbox.py /probe/utils/sandbox.py
COPY mcp_servers/code_execution_server/tests/run_as_user_boundary_driver.py /probe/driver.py

# Container runs as root (as GDM's does); the driver drops commands to gemini.
CMD ["python", "/probe/driver.py"]
